#!/usr/bin/env bash
# ============================================================
# DEERFLOW AGENT ENFORCER — Pre-Commit Hook
# Runs quality gates BEFORE any git commit.
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# ============================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║     DEERFLOW AGENT ENFORCER — Pre-Commit Gate    ║${NC}"
echo -e "${BLUE}║                  v2.0.0 Strict Mode              ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════╝${NC}"
echo ""

FAILED=0
WARNINGS=0
ENFORCEMENT_LEVEL="${DEERFLOW_LEVEL:-strict}"

# === Gate 1: Check for deleted files ===
echo -e "${BLUE}[Gate 1/6] File Safety Check${NC}"
DELETED_FILES=$(git diff --cached --name-only --diff-filter=D 2>/dev/null || true)
if [ -n "$DELETED_FILES" ]; then
    echo -e "${RED}WARNING: DELETED FILES DETECTED:${NC}"
    echo "$DELETED_FILES" | while read -r file; do
        echo -e "${RED}  x $file${NC}"
    done
    echo ""
    echo -e "${YELLOW}DeerFlow: File deletion requires explicit confirmation.${NC}"
    echo -e "${YELLOW}If intentional, commit with: git commit --no-verify -m \"delete: ...\"${NC}"
    FAILED=1
else
    echo -e "${GREEN}  [OK] No unexpected file deletions${NC}"
fi

# === Gate 2: Check for hardcoded secrets ===
echo -e "${BLUE}[Gate 2/6] Secret Detection${NC}"
SECRETS_FOUND=0
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
for file in $STAGED_FILES; do
    case "$file" in
        *.ts|*.tsx|*.js|*.jsx|*.py|*.go|*.rs|*.java)
            DIFF_OUTPUT=$(git diff --cached "$file" 2>/dev/null || true)
            if echo "$DIFF_OUTPUT" | grep -Ei '^\+.*(password|secret|api_key|private_key|token)\s*[:=]\s*["\x27]' > /dev/null 2>&1; then
                if ! echo "$DIFF_OUTPUT" | grep -q 'process\.env\|import\.meta\|os\.environ'; then
                    echo -e "${RED}  [FAIL] Possible hardcoded secret in: $file${NC}"
                    SECRETS_FOUND=1
                fi
            fi
            ;;
    esac
done
if [ "$SECRETS_FOUND" -eq 1 ]; then
    echo -e "${RED}BLOCKED: Hardcoded secrets detected!${NC}"
    FAILED=1
else
    echo -e "${GREEN}  [OK] No hardcoded secrets${NC}"
fi

# === Gate 3: Check for console.log ===
echo -e "${BLUE}[Gate 3/6] Console.log Detection${NC}"
CONSOLE_LOGS=0
for file in $STAGED_FILES; do
    case "$file" in
        *.ts|*.tsx|*.js|*.jsx)
            DIFF_OUTPUT=$(git diff --cached "$file" 2>/dev/null || true)
            if echo "$DIFF_OUTPUT" | grep -E '^\+.*console\.(log|debug|info)\s*\(' > /dev/null 2>&1; then
                if ! echo "$DIFF_OUTPUT" | grep -q 'DEERFLOW:ALLOW\|SAFETY:'; then
                    echo -e "${YELLOW}  [WARN] console.log found in: $file${NC}"
                    CONSOLE_LOGS=1
                fi
            fi
            ;;
    esac
done
if [ "$CONSOLE_LOGS" -eq 1 ]; then
    if [ "$ENFORCEMENT_LEVEL" = "strict" ]; then
        echo -e "${YELLOW}BLOCKED: Remove console.log statements${NC}"
        FAILED=1
    else
        WARNINGS=1
    fi
else
    echo -e "${GREEN}  [OK] No console.log statements${NC}"
fi

# === Gate 4: Check for prohibited patterns ===
echo -e "${BLUE}[Gate 4/6] Prohibited Pattern Detection${NC}"
PATTERNS_FOUND=0
for file in $STAGED_FILES; do
    case "$file" in
        *.ts|*.tsx|*.js|*.jsx)
            DIFF_OUTPUT=$(git diff --cached "$file" 2>/dev/null || true)
            for pattern in "eval\s*\(" "TODO:" "placeholder" "dummy" "@ts-ignore" "eslint-disable"; do
                if echo "$DIFF_OUTPUT" | grep -E "^\+.*$pattern" > /dev/null 2>&1; then
                    if ! echo "$DIFF_OUTPUT" | grep -q "DEERFLOW:ALLOW\|SAFETY:"; then
                        echo -e "${YELLOW}  [WARN] Prohibited pattern '$pattern' in: $file${NC}"
                        PATTERNS_FOUND=1
                    fi
                fi
            done
            ;;
    esac
done
if [ "$PATTERNS_FOUND" -eq 1 ]; then
    if [ "$ENFORCEMENT_LEVEL" = "strict" ]; then
        echo -e "${YELLOW}BLOCKED: Prohibited patterns found${NC}"
        FAILED=1
    else
        WARNINGS=1
    fi
else
    echo -e "${GREEN}  [OK] No prohibited patterns${NC}"
fi

# === Gate 5: Check for TODO/placeholder in new files ===
echo -e "${BLUE}[Gate 5/6] Incomplete Code Detection${NC}"
INCOMPLETE=0
for file in $STAGED_FILES; do
    case "$file" in
        *.ts|*.tsx|*.js|*.jsx|*.py)
            FILE_CONTENT=$(git show ":$file" 2>/dev/null || true)
            if echo "$FILE_CONTENT" | grep -Ei '(TODO|FIXME|HACK|XXX|implement\s+later|stub)' > /dev/null 2>&1; then
                if ! echo "$FILE_CONTENT" | grep -q "DEERFLOW:ALLOW"; then
                    echo -e "${RED}  [FAIL] Incomplete code marker in: $file${NC}"
                    INCOMPLETE=1
                fi
            fi
            ;;
    esac
done
if [ "$INCOMPLETE" -eq 1 ]; then
    echo -e "${RED}BLOCKED: Incomplete code detected — implement fully${NC}"
    FAILED=1
else
    echo -e "${GREEN}  [OK] All code is fully implemented${NC}"
fi

# === Gate 6: TypeScript type check (if applicable) ===
echo -e "${BLUE}[Gate 6/6] Type Safety Check${NC}"
if [ -f "tsconfig.json" ]; then
    if command -v npx > /dev/null 2>&1; then
        if npx tsc --noEmit 2>/dev/null; then
            echo -e "${GREEN}  [OK] TypeScript: No errors${NC}"
        else
            echo -e "${RED}BLOCKED: TypeScript errors found${NC}"
            npx tsc --noEmit 2>&1 | head -20
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  [WARN] npx not found — skipped${NC}"
    fi
else
    echo -e "${GREEN}  [OK] No TypeScript project — skipped${NC}"
fi

# === Summary ===
echo ""
echo -e "${BLUE}══════════════════════════════════════════════════${NC}"
if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}RESULT: COMMIT BLOCKED${NC}"
    echo -e "${RED}   Fix the violations above before committing.${NC}"
    echo -e "${RED}   To override (NOT recommended): git commit --no-verify${NC}"
    exit 1
elif [ "$WARNINGS" -eq 1 ]; then
    echo -e "${YELLOW}RESULT: COMMIT ALLOWED WITH WARNINGS${NC}"
    echo -e "${YELLOW}   Consider fixing the warnings above.${NC}"
    exit 0
else
    echo -e "${GREEN}RESULT: ALL GATES PASSED${NC}"
    echo -e "${GREEN}   Commit approved. DeerFlow quality verified.${NC}"
    exit 0
fi
