#!/usr/bin/env bash
# ============================================================
# DEERFLOW AGENT ENFORCER — Pre-Push Hook
# Runs comprehensive quality gates BEFORE any git push.
# Install: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# ============================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║     DEERFLOW AGENT ENFORCER — Pre-Push Gate      ║${NC}"
echo -e "${BLUE}║                  v2.0.0 Strict Mode              ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════════════╝${NC}"
echo ""

FAILED=0

# === Gate 1: Run tests ===
echo -e "${BLUE}[Gate 1/4] Test Suite${NC}"
if [ -f "package.json" ]; then
    if grep -q '"test"' package.json; then
        if npm test 2>/dev/null; then
            echo -e "${GREEN}  ✓ All tests passing${NC}"
        else
            echo -e "${RED}⛔ BLOCKED: Tests failing${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  ⚠ No test script configured${NC}"
    fi
elif [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then
    if python -m pytest 2>/dev/null; then
        echo -e "${GREEN}  ✓ All tests passing${NC}"
    else
        echo -e "${RED}⛔ BLOCKED: Tests failing${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}  ⚠ No test framework detected${NC}"
fi

# === Gate 2: Build check ===
echo -e "${BLUE}[Gate 2/4] Build Verification${NC}"
if [ -f "package.json" ]; then
    if grep -q '"build"' package.json; then
        if npm run build 2>/dev/null; then
            # Verify build output size
            for dir in dist build .next out; do
                if [ -d "$dir" ]; then
                    SIZE=$(du -sk "$dir" 2>/dev/null | cut -f1)
                    if [ "$SIZE" -lt 10 ]; then
                        echo -e "${RED}⛔ BUILD TOO SMALL: ${SIZE}KB — assets may be missing${NC}"
                        FAILED=1
                    else
                        echo -e "${GREEN}  ✓ Build output: ${SIZE}KB${NC}"
                    fi
                    break
                fi
            done
        else
            echo -e "${RED}⛔ BLOCKED: Build failed${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  ⚠ No build script configured${NC}"
    fi
else
    echo -e "${YELLOW}  ⚠ No build configuration detected${NC}"
fi

# === Gate 3: Security audit ===
echo -e "${BLUE}[Gate 3/4] Security Audit${NC}"
if [ -f "package.json" ] && command -v npm &> /dev/null; then
    AUDIT_RESULT=$(npm audit --audit-level=high --json 2>/dev/null || echo "{}")
    VULN_COUNT=$(echo "$AUDIT_RESULT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('vulnerabilities',{})))" 2>/dev/null || echo "0")
    if [ "$VULN_COUNT" -gt 0 ]; then
        echo -e "${RED}⛔ BLOCKED: $VULN_COUNT high/critical vulnerabilities${NC}"
        npm audit 2>/dev/null | head -10
        FAILED=1
    else
        echo -e "${GREEN}  ✓ No high/critical vulnerabilities${NC}"
    fi
else
    echo -e "${YELLOW}  ⚠ npm audit not available${NC}"
fi

# === Gate 4: Dependency check ===
echo -e "${BLUE}[Gate 4/4] Dependency Integrity${NC}"
if [ -f "package.json" ] && command -v npm &> /dev/null; then
    if npm ls --depth=0 2>&1 | grep -q "UNMET PEER DEPENDENCY"; then
        echo -e "${YELLOW}  ⚠ Unmet peer dependencies detected${NC}"
        npm ls --depth=0 2>&1 | grep "UNMET" || true
    else
        echo -e "${GREEN}  ✓ Dependencies OK${NC}"
    fi
fi

# === Summary ===
echo ""
echo -e "${BLUE}══════════════════════════════════════════════════${NC}"
if [ $FAILED -eq 1 ]; then
    echo -e "${RED}🔴 PUSH BLOCKED${NC}"
    echo -e "${RED}   Fix all issues before pushing.${NC}"
    echo -e "${RED}   To override: git push --no-verify${NC}"
    exit 1
else
    echo -e "${GREEN}🟢 ALL GATES PASSED — Push approved${NC}"
    exit 0
fi
